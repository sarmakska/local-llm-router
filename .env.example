LLR_PORT=3030
LLR_POLICY=./policy.yaml
LLR_DB=./metrics.db

# Ollama (local). The router reaches Ollama at the endpoint set in policy.yaml;
# this variable is a convenience for compose files and scripts.
OLLAMA_URL=http://localhost:11434

# SarmaLink-AI (cloud)
SARMALINK_API_KEY=

# Frontier (OpenAI or any OpenAI-compatible provider)
OPENAI_API_KEY=
